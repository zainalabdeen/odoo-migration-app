<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <record id="discover_models_wizard_form_view" model="ir.ui.view">
            <field name="name">discover.models.wizard.form.view</field>
            <field name="model">discover.models.wizard</field>
            <field name="arch" type="xml">
                <form string="Discover Source Models">
                    <group>
                        <field name="config_id"/>
                        <field name="app_ids" widget="many2many_tags"/>
                        <field name="clear_existing"/>
                        <field name="include_transient"/>
                    </group>
                    <footer>
                        <button name="action_discover" type="object" string="Discover" class="oe_highlight"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>